# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ssp
DB_USER=ssp
DB_PASS=ssp_dev_password

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain

# AI (Anthropic)
ANTHROPIC_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# S3 (optional — for cloud storage)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=ssp-documents
# S3_ENDPOINT=http://localhost:4566

# GitHub (for Claude Code MCP)
# GITHUB_TOKEN=ghp_your_token

# Read-only DB connection (for Claude Code MCP)
# DATABASE_URL_READONLY=postgresql://ssp_reader:password@localhost:5432/ssp
