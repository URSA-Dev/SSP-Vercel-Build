{
  "name": "ssp-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src --ext .js --report-unused-disable-directives --max-warnings 0",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js",
    "db:setup": "npm run migrate && npm run seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "embed": "node scripts/embed-knowledge.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.33.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  }
}
