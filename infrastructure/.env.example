# =============================================================================
# SSP Docker Compose Environment Variables
# Copy to .env and fill in actual values before running docker-compose
# =============================================================================

# Node environment
NODE_ENV=development

# PostgreSQL
POSTGRES_DB=ssp
POSTGRES_USER=ssp
POSTGRES_PASSWORD=CHANGE_ME_db_password

# JWT Authentication
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_string

# pgAdmin
PGADMIN_EMAIL=admin@ursamobile.com
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password

# Redis (optional overrides — defaults work for local dev)
# REDIS_URL=redis://redis:6379
